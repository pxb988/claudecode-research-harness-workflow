{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "extraKnownMarketplaces": {
    "research-harness": {
      "source": {
        "source": "github",
        "repo": "pxb988/claudecode-research-harness-workflow"
      }
    }
  },
  "enabledPlugins": ["claudecode-research-harness-workflow"],
  "permissions": {
    "allow": [
      "Bash(Rscript:*)",
      "Bash(stata:*)",
      "Bash(stata-se:*)",
      "Bash(stata-mp:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(ruff:*)",
      "Bash(black:*)",
      "Bash(mypy:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(head:*)",
      "Bash(file:*)",
      "Bash(mkdir:*)",
      "Bash(icacls:*)",
      "Bash(chmod:*)"
    ],
    "deny": [
      "Write(1.rawdata/**)",
      "Edit(1.rawdata/**)",
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(psql:*)",
      "Bash(mysql:*)",
      "Bash(mongo:*)",
      "Bash(mongod:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*id_rsa*)",
      "Read(**/*id_ed25519*)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)"
    ],
    "ask": [
      "Bash(rm -r:*)",
      "Bash(git reset --hard:*)",
      "Bash(git push:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force:*)",
      "Bash(git rebase:*)",
      "Bash(pip install:*)"
    ]
  },
  "sandbox": {
    "network": {
      "deniedDomains": [
        "169.254.169.254",
        "metadata.google.internal",
        "metadata.azure.com",
        "pastebin.com",
        "transfer.sh",
        "0x0.st",
        "paste.ee",
        "termbin.com",
        "ix.io"
      ]
    }
  }
}
